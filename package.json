{
    "name": "aem-htl-sightly-support",
    "displayName": "AEM HTL Sightly Support",
    "description": "VS Code extension to provide support for AEM HTL (Sightly) files",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:html"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "grammars": [
            {
                "scopeName": "text.html.htl",
                "path": "./syntaxes/htl.tmLanguage.json",
                "injectTo": [
                    "text.html.basic"
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/node": "18.x",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3"
    },
    "dependencies": {
        "fast-xml-parser": "^5.5.5"
    }
}
