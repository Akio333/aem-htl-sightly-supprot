{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "HTL",
    "scopeName": "text.html.htl",
    "injectionSelector": "L:text.html.basic",
    "patterns": [
        {
            "include": "#expressions"
        }
    ],
    "repository": {
        "expressions": {
            "begin": "\\$\\{",
            "end": "\\}",
            "name": "meta.expression.htl",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.expression.begin.htl" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.expression.end.htl" }
            },
            "patterns": [
                {
                    "match": "\\b(true|false)\\b",
                    "name": "constant.language.boolean.htl"
                },
                {
                    "match": "\\b(?:[0-9]+(?:\\.[0-9]+)?)\\b",
                    "name": "constant.numeric.htl"
                },
                {
                    "begin": "'",
                    "end": "'",
                    "name": "string.quoted.single.htl"
                },
                {
                    "match": "\\b(and|or|not|eq|ne|lt|le|gt|ge|in)\\b",
                    "name": "keyword.operator.logical.htl"
                },
                {
                    "match": "(@)\\s*([a-zA-Z_0-9-]+)",
                    "captures": {
                        "1": { "name": "keyword.operator.context.htl" },
                        "2": { "name": "variable.parameter.htl" }
                    }
                },
                {
                    "match": "([a-zA-Z_$][a-zA-Z0-9_$]*)(?:\\.)?",
                    "name": "variable.other.object.htl"
                }
            ]
        }
    }
}
